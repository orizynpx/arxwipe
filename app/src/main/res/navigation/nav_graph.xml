<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/launchFragment">

    <fragment
        android:id="@+id/launchFragment"
        android:name="io.github.orizynpx.arxwipe.ui.launch.LaunchFragment"
        android:label="Launch"
        tools:layout="@layout/fragment_launch">
        <action
            android:id="@+id/action_launchFragment_to_onboardingFragment"
            app:destination="@id/onboardingFragment"
            app:popUpTo="@id/launchFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_launchFragment_to_navigation_discover"
            app:destination="@id/navigation_discover"
            app:popUpTo="@id/launchFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="io.github.orizynpx.arxwipe.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_loginFragment_to_onboardingFragment"
            app:destination="@id/onboardingFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_loginFragment_to_navigation_discover"
            app:destination="@id/navigation_discover"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="io.github.orizynpx.arxwipe.ui.auth.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_registerFragment_to_onboardingFragment"
            app:destination="@id/onboardingFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/onboardingFragment"
        android:name="io.github.orizynpx.arxwipe.ui.onboarding.OnboardingFragment"
        android:label="Onboarding"
        tools:layout="@layout/fragment_onboarding_new">
        <action
            android:id="@+id/action_onboardingFragment_to_navigation_discover"
            app:destination="@id/navigation_discover"
            app:popUpTo="@id/onboardingFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/paperReaderFragment"
        android:name="io.github.orizynpx.arxwipe.ui.reader.PaperReaderFragment"
        android:label="Paper Reader"
        tools:layout="@layout/fragment_paper_reader">
        <argument
            android:name="arxiv_id"
            app:argType="string" />
        <argument
            android:name="reader_mode"
            android:defaultValue="@null"
            app:argType="string"
            app:nullable="true" />
    </fragment>

    <navigation
        android:id="@+id/navigation_discover"
        app:startDestination="@id/discoverFragment">

        <fragment
            android:id="@+id/discoverFragment"
            android:name="io.github.orizynpx.arxwipe.ui.discover.DiscoverFragment"
            android:label="Discover"
            tools:layout="@layout/fragment_discover">
            <action
                android:id="@+id/action_discover_to_paperDetails"
                app:destination="@id/discoverPaperDetailsFragment" />
            <action
                android:id="@+id/action_discover_to_notifications"
                app:destination="@id/receivedNotificationsFragment" />
        </fragment>

        <fragment
            android:id="@+id/receivedNotificationsFragment"
            android:name="io.github.orizynpx.arxwipe.ui.notifications.ReceivedNotificationsFragment"
            android:label="Notifications"
            tools:layout="@layout/fragment_received_notifications">
            <deepLink app:uri="arxwipe://notifications" />
        </fragment>

        <fragment
            android:id="@+id/discoverPaperDetailsFragment"
            android:name="io.github.orizynpx.arxwipe.ui.paperdetails.PaperDetailsFragment"
            android:label="Paper Details"
            tools:layout="@layout/fragment_paper_details">
            <argument
                android:name="arxivId"
                app:argType="string" />
            <action
                android:id="@+id/action_discoverPaperDetails_to_paperReader"
                app:destination="@id/paperReaderFragment" />
        </fragment>
    </navigation>

    <navigation
        android:id="@+id/navigation_search"
        app:startDestination="@id/searchFragment">

        <fragment
            android:id="@+id/searchFragment"
            android:name="io.github.orizynpx.arxwipe.ui.search.SearchFragment"
            android:label="Search"
            tools:layout="@layout/fragment_search">
            <action
                android:id="@+id/action_search_to_paperDetails"
                app:destination="@id/searchPaperDetailsFragment" />
            <action
                android:id="@+id/action_search_to_paperReader"
                app:destination="@id/paperReaderFragment" />
        </fragment>

        <fragment
            android:id="@+id/searchPaperDetailsFragment"
            android:name="io.github.orizynpx.arxwipe.ui.paperdetails.PaperDetailsFragment"
            android:label="Paper Details"
            tools:layout="@layout/fragment_paper_details">
            <argument
                android:name="arxivId"
                app:argType="string" />
            <action
                android:id="@+id/action_searchPaperDetails_to_paperReader"
                app:destination="@id/paperReaderFragment" />
        </fragment>
    </navigation>

    <navigation
        android:id="@+id/navigation_library"
        app:startDestination="@id/libraryFragment">

        <fragment
            android:id="@+id/libraryFragment"
            android:name="io.github.orizynpx.arxwipe.ui.library.LibraryFragment"
            android:label="Library"
            tools:layout="@layout/fragment_library">
            <action
                android:id="@+id/action_library_to_collectionDetails"
                app:destination="@id/collectionDetailsFragment" />
        </fragment>

        <fragment
            android:id="@+id/collectionDetailsFragment"
            android:name="io.github.orizynpx.arxwipe.ui.library.CollectionDetailsFragment"
            android:label="Collection Details"
            tools:layout="@layout/fragment_collection_details">
            <argument
                android:name="collection_id"
                app:argType="string" />
            <action
                android:id="@+id/action_collectionDetails_to_paperDetails"
                app:destination="@id/libraryPaperDetailsFragment" />
            <action
                android:id="@+id/action_collectionDetails_to_paperReader"
                app:destination="@id/paperReaderFragment" />
        </fragment>

        <fragment
            android:id="@+id/libraryPaperDetailsFragment"
            android:name="io.github.orizynpx.arxwipe.ui.paperdetails.PaperDetailsFragment"
            android:label="Paper Details"
            tools:layout="@layout/fragment_paper_details">
            <argument
                android:name="arxivId"
                app:argType="string" />
            <action
                android:id="@+id/action_libraryPaperDetails_to_paperReader"
                app:destination="@id/paperReaderFragment" />
        </fragment>
    </navigation>

    <navigation
        android:id="@+id/navigation_profile"
        app:startDestination="@id/profileFragment">

        <fragment
            android:id="@+id/profileFragment"
            android:name="io.github.orizynpx.arxwipe.ui.profile.ProfileFragment"
            android:label="Profile"
            tools:layout="@layout/fragment_profile">
            <action
                android:id="@+id/action_navigation_profile_to_settingsFragment"
                app:destination="@id/settingsFragment" />
            <action
                android:id="@+id/action_profileFragment_to_loginFragment"
                app:destination="@id/loginFragment" />
        </fragment>

        <fragment
            android:id="@+id/settingsFragment"
            android:name="io.github.orizynpx.arxwipe.ui.settings.SettingsFragment"
            android:label="Settings"
            tools:layout="@layout/fragment_settings" />
    </navigation>

</navigation>
