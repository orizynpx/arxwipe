<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <TextView
            android:id="@+id/tv_paper_title"
            style="?attr/textAppearanceTitleMedium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Paper Title"
            app:layout_constraintEnd_toStartOf="@+id/ib_more"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_paper_authors"
            style="?attr/textAppearanceBodySmall"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Authors"
            app:layout_constraintEnd_toEndOf="@+id/tv_paper_title"
            app:layout_constraintStart_toStartOf="@+id/tv_paper_title"
            app:layout_constraintTop_toBottomOf="@+id/tv_paper_title" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cg_tags"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:chipSpacingHorizontal="4dp"
            app:layout_constraintEnd_toEndOf="@+id/tv_paper_title"
            app:layout_constraintStart_toStartOf="@+id/tv_paper_title"
            app:layout_constraintTop_toBottomOf="@+id/tv_paper_authors" />

        <ImageButton
            android:id="@+id/ib_more"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@android:drawable/ic_menu_more"
            app:tint="?attr/colorOnSurfaceVariant" />

        <LinearLayout
            android:id="@+id/ll_split_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cg_tags">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_read_default"
                style="?attr/materialButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Read PDF"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Button.Left" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_read_dropdown"
                style="?attr/materialButtonStyle"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="-2dp"
                android:padding="0dp"
                app:icon="@android:drawable/arrow_down_float"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Button.Right" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
